@using EduDirectory3
@using EduDirectory3.Data
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin EduDirectory</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
            body {
                background-color: #f4f6f9;
            }

            .sidebar {
                min-height: 100vh;
                background-color: #212529;
                width: 240px;
                position: fixed;
                top: 0;
                left: 0;
                padding-top: 1rem;
                z-index: 100;
            }

                .sidebar .nav-link {
                    color: #adb5bd;
                    padding: .6rem 1.2rem;
                    border-radius: .375rem;
                    margin: 2px 8px;
                }

                    .sidebar .nav-link:hover,
                    .sidebar .nav-link.active {
                        background-color: #343a40;
                        color: #fff;
                    }

                    .sidebar .nav-link i {
                        width: 20px;
                    }

            .sidebar-brand {
                color: #fff;
                font-weight: 700;
                font-size: 1.1rem;
                padding: .5rem 1.2rem 1rem;
                display: block;
                border-bottom: 1px solid #343a40;
                margin-bottom: .5rem;
            }

            .main-content {
                margin-left: 240px;
                padding: 2rem;
                min-height: 100vh;
            }

            .topbar {
                background: #fff;
                border-bottom: 1px solid #dee2e6;
                padding: .75rem 2rem;
                margin-left: 240px;
                position: sticky;
                top: 0;
                z-index: 99;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <span class="sidebar-brand">
            <i class="bi bi-mortarboard-fill me-2 text-primary"></i>EduDirectory
        </span>
        <nav class="nav flex-column">
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
               asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-speedometer2 me-2"></i>Dashboard
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Usuarios" ? "active" : "")"
               asp-area="Admin" asp-controller="Usuarios" asp-action="Index">
                <i class="bi bi-people me-2"></i>Usuarios
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Instituciones" ? "active" : "")"
               asp-area="Admin" asp-controller="Instituciones" asp-action="Index">
                <i class="bi bi-building me-2"></i>Instituciones
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Comentarios" ? "active" : "")"
               asp-area="Admin" asp-controller="Comentarios" asp-action="Index">
                <i class="bi bi-flag me-2"></i>Comentarios reportados
            </a>
        </nav>
    </div>

    <!-- TOPBAR -->
    <div class="topbar">
        <span class="fw-semibold text-muted small">
            <i class="bi bi-person-circle me-1"></i>@User.Identity?.Name
        </span>
        <form asp-area="Identity" asp-page="/Account/Logout"
              asp-route-returnUrl="/" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-outline-danger">
                <i class="bi bi-box-arrow-right me-1"></i>Cerrar sesión
            </button>
        </form>
    </div>

    <!-- CONTENIDO -->
    <div class="main-content">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
