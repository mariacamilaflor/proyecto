@{
    ViewData["Title"] = "Dashboard Admin";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<h4 class="fw-bold mb-4"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h4>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-1 text-primary"><i class="bi bi-people-fill"></i></div>
            <div class="fs-3 fw-bold">@ViewBag.TotalUsuarios</div>
            <div class="text-muted small">Usuarios registrados</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-1 text-success"><i class="bi bi-building"></i></div>
            <div class="fs-3 fw-bold">@ViewBag.TotalInstituciones</div>
            <div class="text-muted small">Instituciones</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-1 text-info"><i class="bi bi-geo-alt-fill"></i></div>
            <div class="fs-3 fw-bold">@ViewBag.TotalSedes</div>
            <div class="text-muted small">Sedes registradas</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-1 text-danger"><i class="bi bi-flag-fill"></i></div>
            <div class="fs-3 fw-bold">@ViewBag.TotalReportados</div>
            <div class="text-muted small">Comentarios reportados</div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <a asp-controller="Usuarios" asp-action="Index" class="card border-0 shadow-sm p-3 d-block text-decoration-none text-dark">
            <i class="bi bi-people me-2 text-primary"></i>Gestionar usuarios
        </a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Instituciones" asp-action="Index" class="card border-0 shadow-sm p-3 d-block text-decoration-none text-dark">
            <i class="bi bi-building me-2 text-success"></i>Gestionar instituciones
        </a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Comentarios" asp-action="Index" class="card border-0 shadow-sm p-3 d-block text-decoration-none text-dark">
            <i class="bi bi-flag me-2 text-danger"></i>Ver reportes
            @if (ViewBag.TotalReportados > 0)
            {
                <span class="badge bg-danger ms-1">@ViewBag.TotalReportados</span>
            }
        </a>
    </div>
</div>

