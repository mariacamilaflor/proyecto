@{
    ViewData["Title"] = "Dashboard Admin";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<h4 class="fw-bold mb-4"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h4>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-1 text-primary"><i class="bi bi-people-fill"></i></div>
            <div class="fs-3 fw-bold">@ViewBag.TotalUsuarios</div>
            <div class="text-muted small">Usuarios registrados</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-1 text-success"><i class="bi bi-building"></i></div>
            <div class="fs-3 fw-bold">@ViewBag.TotalInstituciones</div>
            <div class="text-muted small">Instituciones</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-1 text-info"><i class="bi bi-geo-alt-fill"></i></div>
            <div class="fs-3 fw-bold">@ViewBag.TotalSedes</div>
            <div class="text-muted small">Sedes registradas</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-1 text-danger"><i class="bi bi-flag-fill"></i></div>
            <div class="fs-3 fw-bold">@ViewBag.TotalReportados</div>
            <div class="text-muted small">Comentarios reportados</div>
        </div>
    </div>
</div>



