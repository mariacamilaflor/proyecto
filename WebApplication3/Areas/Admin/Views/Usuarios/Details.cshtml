@model EduDirectory3.Models.Usuario
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Detalle de Usuario";
}

<div class="page-wrapper">

    <div class="page-header">
        <div class="header-left">
            <a href="@Url.Action("Index", "Usuarios", new { area = "Admin" })" class="back-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="15 18 9 12 15 6" />
                </svg>
            </a>
            <div>
                <h1 class="page-title">Detalle de Usuario</h1>
                <p class="page-subtitle">ID #@Model.IdUsuario</p>
            </div>
        </div>
        <a href="@Url.Action("Edit", "Usuarios", new { area = "Admin", id = Model.IdUsuario })"
           class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
            </svg>
            Editar
        </a>
    </div>

    <div class="detail-card">

        <!-- Avatar + nombre -->
        <div class="profile-header">
            <div class="profile-avatar">
                @Model.Nombre.Substring(0, 1).ToUpper()@Model.Apellido.Substring(0, 1).ToUpper()
            </div>
            <div>
                <h2 class="profile-name">@Model.Nombre @Model.Apellido</h2>
                <span class="rol-badge rol-@Model.Rol.ToLower()">@Model.Rol</span>
            </div>
        </div>

        <div class="divider"></div>

        <!-- Datos -->
        <div class="detail-grid">
            <div class="detail-item">
                <span class="detail-label">Nombre</span>
                <span class="detail-value">@Model.Nombre</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Apellido</span>
                <span class="detail-value">@Model.Apellido</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Correo electrónico</span>
                <span class="detail-value">@Model.Correo</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Rol asignado</span>
                <span class="detail-value">
                    <span class="rol-badge rol-@Model.Rol.ToLower()">@Model.Rol</span>
                </span>
            </div>
            <div class="detail-item">
                <span class="detail-label">ID de usuario</span>
                <span class="detail-value">#@Model.IdUsuario</span>
            </div>
        </div>

        <div class="divider"></div>

        <!-- Acciones -->
        <div class="detail-actions">
            <a href="@Url.Action("Index", "Usuarios", new { area = "Admin" })" class="btn btn-secondary">
                Volver al listado
            </a>
            <div style="display:flex; gap:.5rem;">
                <a href="@Url.Action("Edit", "Usuarios", new { area = "Admin", id = Model.IdUsuario })"
                   class="btn btn-outline">
                    Editar usuario
                </a>
                <form action="@Url.Action("Delete", "Usuarios", new { area = "Admin", id = Model.IdUsuario })"
                      method="post"
                      onsubmit="return confirm('¿Eliminar a @Model.Nombre @Model.Apellido permanentemente?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Eliminar usuario</button>
                </form>
            </div>
        </div>

    </div>
</div>

<style>
    :root {
        --bg: #0f1117;
        --surface: #181c27;
        --surface2: #1e2333;
        --border: #2a2f45;
        --accent: #4f46e5;
        --accent-ok: #3ecf8e;
        --accent-warn: #f59e0b;
        --accent-red: #e05c5c;
        --text: #e2e8f0;
        --text-muted: #64748b;
        --radius: 10px;
    }

    .page-wrapper {
        padding: 2rem;
        max-width: 700px;
        margin: 0 auto;
        font-family: 'Segoe UI', system-ui, sans-serif;
        color: var(--text);
    }

    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.75rem;
    }

    .header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .back-btn {
        width: 36px;
        height: 36px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
        text-decoration: none;
        transition: all .15s;
        flex-shrink: 0;
    }

        .back-btn:hover {
            color: var(--text);
            border-color: var(--accent);
        }

    .page-title {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0 0 .2rem;
        letter-spacing: -.02em;
    }

    .page-subtitle {
        font-size: .85rem;
        color: var(--text-muted);
        margin: 0;
    }

    .detail-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
    }

    .profile-header {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        padding: 1.75rem;
    }

    .profile-avatar {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        font-weight: 700;
        color: #fff;
        flex-shrink: 0;
    }

    .profile-name {
        font-size: 1.25rem;
        font-weight: 700;
        margin: 0 0 .4rem;
    }

    .divider {
        height: 1px;
        background: var(--border);
    }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
    }

    .detail-item {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--border);
    }

        .detail-item:nth-last-child(-n+2) {
            border-bottom: none;
        }

    .detail-label {
        display: block;
        font-size: .75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: var(--text-muted);
        margin-bottom: .3rem;
    }

    .detail-value {
        font-size: .95rem;
        color: var(--text);
        font-weight: 500;
    }

    .rol-badge {
        display: inline-block;
        padding: .25rem .75rem;
        border-radius: 20px;
        font-size: .75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .rol-admin {
        background: rgba(224,92,92,.12);
        border: 1px solid rgba(224,92,92,.3);
        color: #e05c5c;
    }

    .rol-institucion {
        background: rgba(245,158,11,.1);
        border: 1px solid rgba(245,158,11,.25);
        color: var(--accent-warn);
    }

    .rol-usuario {
        background: rgba(62,207,142,.1);
        border: 1px solid rgba(62,207,142,.25);
        color: var(--accent-ok);
    }

    .detail-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem 1.5rem;
        background: var(--surface2);
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .55rem 1.1rem;
        border: none;
        border-radius: 7px;
        font-size: .875rem;
        font-weight: 500;
        cursor: pointer;
        transition: opacity .15s, transform .1s;
        text-decoration: none;
    }

        .btn:hover {
            opacity: .85;
            transform: translateY(-1px);
        }

    .btn-primary {
        background: var(--accent);
        color: #fff;
    }

    .btn-outline {
        background: rgba(79,70,229,.1);
        border: 1px solid rgba(79,70,229,.3);
        color: #a5b4fc;
    }

    .btn-secondary {
        background: var(--surface);
        border: 1px solid var(--border);
        color: var(--text-muted);
    }

    .btn-danger {
        background: rgba(224,92,92,.12);
        border: 1px solid rgba(224,92,92,.3);
        color: var(--accent-red);
    }
</style>

