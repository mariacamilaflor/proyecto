@model List<EduDirectory3.Models.Institucion>
@using EduDirectory3
@using EduDirectory3.Data
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Gestión de Instituciones";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-building me-2"></i>Instituciones</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Nueva institución
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Nombre</th>
                        <th>Tipo</th>
                        <th>Metodología</th>
                        <th>Sedes</th>
                        <th>Usuario</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">No hay instituciones registradas.</td>
                        </tr>
                    }
                    @foreach (var inst in Model)
                    {
                        <tr>
                            <td>@inst.IdInstitucion</td>
                            <td class="fw-semibold">@inst.Nombre</td>
                            <td>@(inst.Tipo ?? "—")</td>
                            <td>@(inst.Metodologia ?? "—")</td>
                            <td><span class="badge bg-secondary">@inst.Sede?.Count</span></td>
                            <td class="small text-muted">@(inst.IdUsuarioNavigation?.Nombre ?? "—")</td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@inst.IdInstitucion"
                                   class="btn btn-sm btn-outline-secondary me-1" title="Ver">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@inst.IdInstitucion"
                                   class="btn btn-sm btn-outline-primary me-1" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" method="post" class="d-inline"
                                      onsubmit="return confirm('¿Eliminar institución @inst.Nombre?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@inst.IdInstitucion" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
