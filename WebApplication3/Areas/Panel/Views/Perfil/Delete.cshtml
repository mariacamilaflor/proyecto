@model EduDirectory3.Models.Institucion
@{
    ViewData["Title"] = "Eliminar Institución";
    Layout = "~/Areas/Panel/Views/Shared/_PanelLayout.cshtml";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-7">

        <!-- TARJETA DE ADVERTENCIA -->
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-danger text-white fw-semibold">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                Confirmar eliminación
            </div>
            <div class="card-body">

                <div class="alert alert-danger d-flex align-items-start gap-3 mb-4">
                    <i class="bi bi-shield-x fs-3 flex-shrink-0 mt-1"></i>
                    <div>
                        <p class="fw-semibold mb-1">Esta acción es permanente e irreversible.</p>
                        <p class="mb-0 small">
                            Se eliminarán todos los datos de tu institución, incluyendo sedes,
                            evaluaciones, fotos y tu cuenta de acceso al panel.
                            <strong>No podrás recuperar esta información.</strong>
                        </p>
                    </div>
                </div>

                <!-- RESUMEN DE LO QUE SE ELIMINARÁ -->
                <h6 class="fw-semibold mb-3">Se eliminará lo siguiente:</h6>

                <ul class="list-group list-group-flush mb-4">
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span><i class="bi bi-building me-2 text-danger"></i>Institución</span>
                        <span class="fw-semibold">@Model.Nombre</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span><i class="bi bi-geo-alt me-2 text-danger"></i>Sedes</span>
                        <span class="badge bg-danger rounded-pill">@(Model.Sede?.Count ?? 0)</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span><i class="bi bi-person-circle me-2 text-danger"></i>Tu cuenta de acceso</span>
                        <span class="badge bg-danger rounded-pill">1</span>
                    </li>
                </ul>

                <!-- CONFIRMACIÓN CON NOMBRE -->
                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        Para confirmar, escribe el nombre de tu institución:
                        <code>@Model.Nombre</code>
                    </label>
                    <input type="text" id="confirmNombre" class="form-control"
                           placeholder="Escribe el nombre exacto..." />
                    <div class="form-text text-danger d-none" id="errorConfirm">
                        El nombre no coincide.
                    </div>
                </div>

                <!-- BOTONES -->
                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Cancelar, no eliminar
                    </a>
                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger" id="btnEliminar" disabled>
                            <i class="bi bi-trash-fill me-1"></i>Sí, eliminar todo
                        </button>
                    </form>
                </div>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        const nombreEsperado = "@Model.Nombre".trim();
        const input = document.getElementById('confirmNombre');
        const btn = document.getElementById('btnEliminar');
        const error = document.getElementById('errorConfirm');

        input.addEventListener('input', function () {
            const val = this.value.trim();
            if (val === nombreEsperado) {
                btn.disabled = false;
                error.classList.add('d-none');
            } else {
                btn.disabled = true;
                if (val.length > 0) {
                    error.classList.remove('d-none');
                } else {
                    error.classList.add('d-none');
                }
            }
        });
    </script>
}

