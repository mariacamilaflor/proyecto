@* /Areas/Admin/Views/Shared/_Layout.cshtml *@
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — EduDirectory</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
            :root {
                --sidebar-w: 240px;
                --brand: #0d6efd;
            }

            body {
                background: #f5f6fa;
                min-height: 100vh;
            }

            /* ── SIDEBAR ── */
            #sidebar {
                width: var(--sidebar-w);
                min-height: 100vh;
                background: #fff;
                border-right: 1px solid #e9ecef;
                position: fixed;
                top: 0;
                left: 0;
                display: flex;
                flex-direction: column;
                z-index: 100;
                transition: transform .25s ease;
            }

                #sidebar .brand {
                    padding: 1.25rem 1.5rem;
                    border-bottom: 1px solid #e9ecef;
                }

                #sidebar .nav-link {
                    color: #6c757d;
                    border-radius: 8px;
                    margin: 2px 12px;
                    padding: 10px 14px;
                    font-size: .875rem;
                    display: flex;
                    align-items: center;
                    gap: 10px;
                    transition: all .15s;
                }

                    #sidebar .nav-link:hover {
                        background: #f0f4ff;
                        color: var(--brand);
                    }

                    #sidebar .nav-link.active {
                        background: #e8f0fe;
                        color: var(--brand);
                        font-weight: 600;
                    }

                    #sidebar .nav-link i {
                        font-size: 1rem;
                        width: 18px;
                        text-align: center;
                    }

            /* ── MAIN ── */
            #main {
                margin-left: var(--sidebar-w);
                min-height: 100vh;
                display: flex;
                flex-direction: column;
            }

            #topbar {
                background: #fff;
                border-bottom: 1px solid #e9ecef;
                padding: .75rem 1.5rem;
                position: sticky;
                top: 0;
                z-index: 99;
            }


            #sidebar.open {
                transform: translateX(0);
            }

            #main {
                margin-left: 0;
            }
    </style>
</head>
<body>

    <!-- ── SIDEBAR ── -->
    <nav id="sidebar">
        <div class="brand d-flex align-items-center gap-2">
            <div class="bg-primary rounded-2 d-flex align-items-center justify-content-center"
                 style="width:32px;height:32px;">
                <i class="bi bi-building-fill text-white" style="font-size:.9rem;"></i>
            </div>
            <div>
                <p class="mb-0 fw-bold" style="font-size:.85rem; line-height:1.1;">EduDirectory</p>
                <p class="mb-0 text-muted" style="font-size:.7rem;">Panel institución</p>
            </div>
        </div>

        <div class="py-3 flex-grow-1 overflow-auto">
            <p class="text-uppercase text-muted px-4 mb-1" style="font-size:.65rem; letter-spacing:.08em;">Principal</p>

            <a asp-area="Institucion" asp-controller="Dashboard" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                <i class="bi bi-grid"></i> Dashboard
            </a>

            <a asp-area="Institucion" asp-controller="Perfil" asp-action="Edit"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Perfil" ? "active" : "")">
                <i class="bi bi-pencil-square"></i> Editar perfil
            </a>

            <a asp-area="Institucion" asp-controller="Sedes" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Sedes" ? "active" : "")">
                <i class="bi bi-building"></i> Sedes
            </a>

            <p class="text-uppercase text-muted px-4 mt-3 mb-1" style="font-size:.65rem; letter-spacing:.08em;">Comunidad</p>

            <a asp-area="Institucion" asp-controller="Opiniones" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Opiniones" ? "active" : "")">
                <i class="bi bi-chat-dots"></i> Opiniones
            </a>

            <p class="text-uppercase text-muted px-4 mt-3 mb-1" style="font-size:.65rem; letter-spacing:.08em;">Inteligencia</p>

            <a asp-area="Institucion" asp-controller="Recomendaciones" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Recomendaciones" ? "active" : "")">
                <i class="bi bi-stars"></i> Recomendaciones ML
            </a>
        </div>

        <!-- Usuario logueado -->
        <div class="p-3 border-top">
            <div class="d-flex align-items-center gap-2">
                <div class="bg-primary-subtle rounded-circle d-flex align-items-center justify-content-center fw-bold text-primary"
                     style="width:34px;height:34px;font-size:.75rem;">
                    @User.Identity.Name?.Substring(0, 2).ToUpper()
                </div>
                <div class="flex-grow-1 overflow-hidden">
                    <p class="mb-0 fw-semibold small text-truncate">@User.Identity.Name</p>
                    <p class="mb-0 text-muted" style="font-size:.7rem;">Institución</p>
                </div>
                <a asp-area="" asp-controller="Account" asp-action="Logout"
                   class="btn btn-link p-0 text-muted" title="Cerrar sesión">
                    <i class="bi bi-box-arrow-right"></i>
                </a>
            </div>
        </div>
    </nav>

    <!-- ── MAIN ── -->
    <div id="main">
        <!-- Topbar -->
        <div id="topbar" class="d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-link p-0 d-md-none" onclick="toggleSidebar()">
                    <i class="bi bi-list fs-5"></i>
                </button>
                <h6 class="mb-0 fw-semibold">@ViewData["Title"]</h6>
            </div>
            <a asp-area="" asp-controller="Home" asp-action="Index"
               class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Ver portal
            </a>
        </div>

        <!-- Contenido -->
        <div class="p-4">
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
        document.getElementById('sidebar').classList.toggle('open');
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>