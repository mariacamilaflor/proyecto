@* /Areas/Panel/Views/Shared/_Layout.cshtml *@
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — EduDirectory</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
            :root {
                --sidebar-w: 240px;
                --verde: #1a7a4a;
                --verde-claro: #e8f5ee;
            }

            * {
                box-sizing: border-box;
            }

            body {
                background: #f4f7f6;
                min-height: 100vh;
                margin: 0;
                overflow-x: hidden;
            }

            /* ── SIDEBAR ── */
            #sidebar {
                width: var(--sidebar-w);
                height: 100vh;
                background: #fff;
                border-right: 1px solid #e0ebe5;
                position: fixed;
                top: 0;
                left: 0;
                display: flex;
                flex-direction: column;
                z-index: 200;
                transition: transform .25s ease;
            }

                #sidebar .brand {
                    padding: 1.25rem 1.5rem;
                    border-bottom: 1px solid #e0ebe5;
                    flex-shrink: 0;
                }

                #sidebar .nav-section {
                    padding: 1rem 0.75rem 0.25rem;
                    font-size: 0.68rem;
                    font-weight: 700;
                    text-transform: uppercase;
                    letter-spacing: 1px;
                    color: #9db8a8;
                }

                #sidebar .nav-link {
                    color: #6b7c74;
                    border-radius: 10px;
                    margin: 2px 10px;
                    padding: 10px 14px;
                    font-size: .875rem;
                    display: flex;
                    align-items: center;
                    gap: 10px;
                    transition: all .15s;
                    text-decoration: none;
                }

                    #sidebar .nav-link:hover {
                        background: var(--verde-claro);
                        color: var(--verde);
                    }

                    #sidebar .nav-link.active {
                        background: var(--verde-claro);
                        color: var(--verde);
                        font-weight: 700;
                    }

                    #sidebar .nav-link i {
                        font-size: 1rem;
                        width: 20px;
                        text-align: center;
                        flex-shrink: 0;
                    }

                /* Nav scrollable en el medio */
                #sidebar .nav-body {
                    flex: 1;
                    overflow-y: auto;
                    padding-bottom: 1rem;
                }

                /* Usuario al fondo */
                #sidebar .sidebar-footer {
                    padding: 1rem;
                    border-top: 1px solid #e0ebe5;
                    flex-shrink: 0;
                }

            /* ── MAIN ── */
            #main {
                margin-left: var(--sidebar-w);
                min-height: 100vh;
                display: flex;
                flex-direction: column;
            }

            /* ── TOPBAR ── */
            #topbar {
                background: #fff;
                border-bottom: 1px solid #e0ebe5;
                padding: .75rem 1.5rem;
                position: sticky;
                top: 0;
                z-index: 99;
                flex-shrink: 0;
            }

            /* ── OVERLAY mobile ── */
            #overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,0.4);
                z-index: 199;
            }

    </style>
</head>
<body>

    <!-- Overlay mobile -->
    <div id="overlay" onclick="closeSidebar()"></div>

    <!-- ── SIDEBAR ── -->
    <nav id="sidebar">

        <!-- Brand -->
        <div class="brand d-flex align-items-center gap-2">
            <div class="d-flex align-items-center justify-content-center rounded-2"
                 style="width:32px;height:32px;background:var(--verde);">
                <i class="bi bi-building-fill text-white" style="font-size:.9rem;"></i>
            </div>
            <div>
                <p class="mb-0 fw-bold" style="font-size:.85rem;line-height:1.1;">EduDirectory</p>
                <p class="mb-0 text-muted" style="font-size:.7rem;">Panel institución</p>
            </div>
        </div>

        <!-- Nav links -->
        <div class="nav-body">
            <div class="nav-section">Principal</div>

            <a asp-area="Panel" asp-controller="Dashboard" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>

            <a asp-area="Panel" asp-controller="Dashboard" asp-action="Perfil"
               class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Perfil" ? "active" : "")">
                <i class="bi bi-building"></i> Mi Institución
            </a>

            <div class="nav-section">Comunicación</div>

            <a asp-area="Panel" asp-controller="Dashboard" asp-action="Mensajes"
               class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Mensajes" ? "active" : "")">
                <i class="bi bi-chat-dots"></i> Mensajes
            </a>

            <div class="nav-section">Reportes</div>

            <a asp-area="Panel" asp-controller="Dashboard" asp-action="Evaluaciones"
               class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Evaluaciones" ? "active" : "")">
                <i class="bi bi-star"></i> Evaluaciones
            </a>
            <a href="/Panel/Sedes/Index" class="nav-link ...">
                <i class="bi bi-geo-alt"></i> Sedes
            </a>

            <a href="/Panel/Sedes/InfoInstitucion" class="nav-link ...">
                <i class="bi bi-info-circle"></i> Info institución
            </a>
            <a href="/Panel/Evento/Index" class="nav-link ...">
                <i class="bi bi-info-circle"></i> Eventos
            </a>
        </div>

        <!-- Footer usuario -->
        <div class="sidebar-footer">
            <div class="d-flex align-items-center gap-2">
                <div class="d-flex align-items-center justify-content-center rounded-circle fw-bold"
                     style="width:34px;height:34px;font-size:.75rem;background:var(--verde-claro);color:var(--verde);flex-shrink:0;">
                    @(User.Identity?.Name?.Substring(0, 2).ToUpper() ?? "IN")
                </div>
                <div class="flex-grow-1 overflow-hidden">
                    <p class="mb-0 fw-semibold small text-truncate">@User.Identity?.Name</p>
                    <p class="mb-0 text-muted" style="font-size:.7rem;">Institución</p>
                </div>
                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                    <button type="submit" class="nav-link btn btn-primary" title="Cerrar sesión">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <!-- ── MAIN ── -->
    <div id="main">

        <!-- Topbar -->
        <div id="topbar" class="d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-3">
                <!-- Botón hamburguesa solo en mobile -->
                <button class="btn btn-link p-0 d-md-none text-muted" onclick="openSidebar()">
                    <i class="bi bi-list fs-4"></i>
                </button>
                <h6 class="mb-0 fw-semibold" style="color:#1c2b22;">@ViewData["Title"]</h6>
            </div>
            <a asp-area="Panel" asp-controller="Dashboard" asp-action="Index"
               class="btn btn-sm" style="border:1.5px solid #e0ebe5;border-radius:8px;font-size:0.82rem;color:#6b7c74;">
                <i class="bi bi-arrow-left me-1"></i>Ver portal
            </a>
        </div>

        <!-- Contenido -->
        <div class="p-4">
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function openSidebar() {
        document.getElementById('sidebar').classList.add('open');
        document.getElementById('overlay').classList.add('show');
        }

        function closeSidebar() {
        document.getElementById('sidebar').classList.remove('open');
        document.getElementById('overlay').classList.remove('show');
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
