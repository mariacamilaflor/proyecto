@model EduDirectory3.Models.Institucion
@{
    ViewData["Title"] = "Registra tu Institución";
    Layout = "~/Areas/Panel/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --verde: #1a7a4a;
        --fondo: #f4f7f6;
        --card: #ffffff;
        --texto: #1c2b22;
        --gris: #6b7c74;
        --borde: #e0ebe5;
    }

    .bienvenida {
        background: linear-gradient(135deg, var(--verde) 0%, #145c38 100%);
        color: white;
        border-radius: 16px;
        padding: 2rem 2.5rem;
        margin-bottom: 2rem;
        box-shadow: 0 4px 20px rgba(26,122,74,0.25);
    }

        .bienvenida h2 {
            margin: 0;
            font-weight: 800;
            font-size: 1.5rem;
        }

        .bienvenida p {
            margin: 0.4rem 0 0;
            opacity: 0.85;
            font-size: 0.9rem;
        }

    .card-seccion {
        background: var(--card);
        border-radius: 16px;
        border: 1px solid var(--borde);
        padding: 2rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }

        .card-seccion h5 {
            color: var(--verde);
            font-weight: 700;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 1.2rem;
            padding-bottom: 0.6rem;
            border-bottom: 2px solid var(--borde);
        }

    .form-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--gris);
    }

    .form-control, .form-select {
        border: 1.5px solid var(--borde);
        border-radius: 10px;
        padding: 0.6rem 0.9rem;
        font-size: 0.9rem;
        transition: border-color 0.2s;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--verde);
            box-shadow: 0 0 0 3px rgba(26,122,74,0.1);
        }

    .img-preview {
        width: 120px;
        height: 120px;
        border-radius: 14px;
        object-fit: cover;
        border: 3px dashed var(--borde);
        margin-bottom: 0.8rem;
        background: var(--fondo);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-guardar {
        background: var(--verde);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 0.7rem 2rem;
        font-weight: 700;
        font-size: 0.95rem;
        transition: background 0.2s;
    }

        .btn-guardar:hover {
            background: #145c38;
            color: white;
        }

    .paso {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        background: var(--verde);
        color: white;
        border-radius: 50%;
        font-size: 0.75rem;
        font-weight: 700;
        margin-right: 0.5rem;
    }
</style>

<div class="bienvenida">
    <h2>¡Bienvenido! Registra tu institución</h2>
    <p>Completa el formulario para comenzar a gestionar tu institución en el directorio.</p>
</div>

<form asp-action="Crear" method="post" enctype="multipart/form-data">

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    @* INFORMACIÓN GENERAL *@
    <div class="card-seccion">
        <h5><span class="paso">1</span> Información General</h5>
        <div class="row g-3">
            <div class="col-md-8">
                <label asp-for="Nombre" class="form-label">Nombre de la Institución</label>
                <input asp-for="Nombre" class="form-control" placeholder="Ej: Colegio San José" />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Tipo" class="form-label">Tipo</label>
                <select asp-for="Tipo" class="form-select">
                    <option value="">-- Seleccione --</option>
                    <option value="Pública">Pública</option>
                    <option value="Privada">Privada</option>
                </select>
                <span asp-validation-for="Tipo" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="Descripcion" class="form-label">Descripción</label>
                <textarea asp-for="Descripcion" class="form-control" rows="4"
                          placeholder="Describe brevemente tu institución..."></textarea>
                <span asp-validation-for="Descripcion" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="PaginaWeb" class="form-label">Página Web</label>
                <input asp-for="PaginaWeb" class="form-control" placeholder="https://..." />
                <span asp-validation-for="PaginaWeb" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="HorarioAtencion" class="form-label">Horario de Atención</label>
                <input asp-for="HorarioAtencion" class="form-control" placeholder="Lun-Vie 7am-5pm" />
                <span asp-validation-for="HorarioAtencion" class="text-danger small"></span>
            </div>
        </div>
    </div>

    @* ACADÉMICO *@
    <div class="card-seccion">
        <h5><span class="paso">2</span> Información Académica</h5>
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="Metodologia" class="form-label">Metodología</label>
                <select asp-for="Metodologia" class="form-select">
                    <option value="">-- Seleccione --</option>
                    <option value="Gamificación">Gamificación</option>
                    <option value="Educación Tradicional">Educación Tradicional</option>
                    <option value="Aprendizaje Basado en Proyectos (ABP)">Aprendizaje Basado en Proyectos (ABP)</option>
                    <option value="Aprendizaje Cooperativo">Aprendizaje Cooperativo</option>
                    <option value="Aprendizaje Basado en Competencias">Aprendizaje Basado en Competencias</option>
                    <option value="Flipped Classroom (Aula Invertida)">Flipped Classroom (Aula Invertida)</option>
                    <option value="Pedagogías alternativas">Pedagogías alternativas</option>
                </select>
                <span asp-validation-for="Metodologia" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Calendario" class="form-label">Calendario</label>
                <select asp-for="Calendario" class="form-select">
                    <option value="">-- Seleccione --</option>
                    <option value="A">Calendario A</option>
                    <option value="B">Calendario B</option>
                </select>
                <span asp-validation-for="Calendario" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Costo" class="form-label">Costo mensual (COP)</label>
                <input asp-for="Costo" class="form-control" type="number" step="0.01" min="0" placeholder="0" />
                <span asp-validation-for="Costo" class="text-danger small"></span>
            </div>
        </div>
    </div>

    @* IMAGEN *@
    <div class="card-seccion">
        <h5><span class="paso">3</span> Logo / Imagen</h5>
        <img id="preview" src="/Imagen/school.png" class="img-preview" />
        <div>
            <input type="file" name="imagenFile" class="form-control" accept="image/*"
                   onchange="document.getElementById('preview').src = window.URL.createObjectURL(this.files[0])" />
            <small class="text-muted">Formatos: JPG, PNG, WEBP. Máximo 2MB.</small>
        </div>
    </div>

    <button type="submit" class="btn-guardar btn">Registrar Institución</button>
</form>

