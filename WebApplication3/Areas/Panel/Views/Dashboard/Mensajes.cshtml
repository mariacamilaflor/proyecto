@model IEnumerable<EduDirectory3.Models.FormularioContacto>
@{
    ViewData["Title"] = "Mensajes";
    Layout = "~/Areas/Panel/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --verde: #1a7a4a;
        --fondo: #f4f7f6;
        --card: #ffffff;
        --texto: #1c2b22;
        --gris: #6b7c74;
        --borde: #e0ebe5;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.8rem;
    }

        .page-header h2 {
            margin: 0;
            font-weight: 800;
            color: var(--texto);
        }

        .page-header p {
            margin: 0;
            color: var(--gris);
            font-size: 0.88rem;
        }

    .mensaje-card {
        background: var(--card);
        border: 1px solid var(--borde);
        border-radius: 14px;
        padding: 1.4rem 1.6rem;
        margin-bottom: 1rem;
        transition: all 0.2s;
        box-shadow: 0 2px 6px rgba(0,0,0,0.04);
        cursor: pointer;
    }

        .mensaje-card:hover {
            border-color: var(--verde);
            box-shadow: 0 4px 16px rgba(26,122,74,0.12);
            transform: translateX(4px);
        }

    .mensaje-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 0.5rem;
    }

    .msg-nombre {
        font-weight: 700;
        font-size: 0.95rem;
        color: var(--texto);
    }

    .msg-sede {
        font-size: 0.78rem;
        background: #e8f5ee;
        color: var(--verde);
        padding: 0.2rem 0.7rem;
        border-radius: 20px;
        font-weight: 600;
    }

    .msg-correo {
        font-size: 0.82rem;
        color: var(--gris);
        margin-bottom: 0.5rem;
    }

    .msg-texto {
        font-size: 0.88rem;
        color: #3a4a40;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .btn-ver {
        font-size: 0.8rem;
        color: var(--verde);
        border: 1.5px solid var(--verde);
        border-radius: 8px;
        padding: 0.3rem 0.9rem;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.2s;
        display: inline-block;
        margin-top: 0.8rem;
    }

        .btn-ver:hover {
            background: var(--verde);
            color: white;
        }

    .vacio {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--gris);
    }

        .vacio .icon {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

    /* Modal */
    .modal-content {
        border-radius: 16px;
        border: none;
    }

    .modal-header {
        background: linear-gradient(135deg, var(--verde), #145c38);
        color: white;
        border-radius: 16px 16px 0 0;
    }

        .modal-header .btn-close {
            filter: invert(1);
        }

    .modal-body {
        padding: 1.8rem;
    }

    .detalle-campo {
        margin-bottom: 1rem;
    }

        .detalle-campo label {
            font-size: 0.78rem;
            font-weight: 700;
            color: var(--gris);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .detalle-campo p {
            margin: 0.2rem 0 0;
            color: var(--texto);
            font-size: 0.92rem;
        }

    .msg-completo {
        background: var(--fondo);
        border-radius: 10px;
        padding: 1rem;
        font-size: 0.9rem;
        line-height: 1.6;
        color: var(--texto);
        border: 1px solid var(--borde);
    }

    .btn-volver {
        border: 1.5px solid var(--borde);
        border-radius: 10px;
        padding: 0.5rem 1.2rem;
        font-size: 0.88rem;
        color: var(--gris);
        text-decoration: none;
        transition: all 0.2s;
    }

        .btn-volver:hover {
            border-color: var(--verde);
            color: var(--verde);
        }
</style>

<div class="page-header">
    <div>
        <h2>💬 Mensajes</h2>
        <p>@Model.Count() mensajes recibidos de usuarios</p>
    </div>
    <a asp-action="Index" class="btn-volver">← Dashboard</a>
</div>

@if (!Model.Any())
{
    <div class="vacio">
        <div class="icon">📭</div>
        <h5>Sin mensajes aún</h5>
        <p>Cuando los usuarios te contacten, aparecerán aquí.</p>
    </div>
}
else
{
    foreach (var msg in Model)
    {
        <div class="mensaje-card" data-bs-toggle="modal" data-bs-target="#modal-@msg.IdFormularioContacto">
            <div class="mensaje-top">
                <div>
                    <div class="msg-nombre">@msg.Nombre</div>
                    <div class="msg-correo">✉️ @msg.IdUsuarioNavigation?.Correo</div>
                </div>
                <span class="msg-sede">@msg.IdSedeNavigation?.NombreSede</span>
            </div>
            <div class="msg-texto">@msg.Mensaje</div>
            <span class="btn-ver">Ver mensaje completo →</span>
        </div>

        <!-- Modal detalle -->
        <div class="modal fade" id="modal-@msg.IdFormularioContacto" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Mensaje de @msg.Nombre</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-6 detalle-campo">
                                <label>Remitente</label>
                                <p>@msg.Nombre</p>
                            </div>
                            <div class="col-6 detalle-campo">
                                <label>Correo</label>
                                <p>@msg.IdUsuarioNavigation?.Correo</p>
                            </div>
                            <div class="col-12 detalle-campo">
                                <label>Sede contactada</label>
                                <p>@msg.IdSedeNavigation?.NombreSede</p>
                            </div>
                            <div class="col-12 detalle-campo">
                                <label>Mensaje</label>
                                <div class="msg-completo">@msg.Mensaje</div>
                            </div>
                        </div>
                        <a href="mailto:@msg.IdUsuarioNavigation?.Correo?subject=Re: Consulta sobre @msg.IdSedeNavigation?.NombreSede"
                           class="btn w-100 mt-3"
                           style="background:var(--verde);color:white;border-radius:10px;font-weight:700;">
                            📧 Responder por correo
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
}
