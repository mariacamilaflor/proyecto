@page
@model LoginModel

@{
    ViewData["Title"] = "Inicio de sesión";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portal Institucional - Colegio Pro</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <!-- Google Fonts - Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <style>
            :root {
                --bs-primary: #1e40af; /* Azul institucional profundo */
                --bs-primary-hover: #1d4ed8;
                --bs-body-font-family: 'Inter', sans-serif;
            }


            body {
                font-family: var(--bs-body-font-family);
                background-color: #f8fafc;
                min-height: 100vh;
            }

            .fw-black {
                font-weight: 900 !important;
            }

            /* Efectos de transición suaves para el formulario */
            .fade-in-custom {
                animation: fadeIn 0.4s ease-in-out forwards;
            }

            /* Estilizado fino de inputs de Bootstrap al enfocarse */
            .form-control:focus {
                background-color: #ffffff !important;
                border-color: var(--bs-primary) !important;
                box-shadow: 0 0 0 0.25rem rgba(30, 64, 175, 0.15) !important;
            }

            /* Ajuste de inputs combinados con iconos */
            .input-group:focus-within .input-group-text {
                border-color: var(--bs-primary) !important;
                background-color: #ffffff !important;
                color: var(--bs-primary) !important;
            }

            .input-group-text {
                transition: all 0.2s ease-in-out;
            }

            /* Ilustración de fondo geométrico sutil */
            .pattern-bg {
                background-image: radial-gradient(rgba(255, 255, 255, 0.15) 1.5px, transparent 1.5px);
                background-size: 24px 24px;
            }
    </style>
</head>
<body class="m-0">

    <div class="container-fluid vh-100 p-0">
        <div class="row g-0 h-100">
            <div class="col-12">
                <div class="h-100">
                    <div class="row g-0 h-100">

                        <!-- COLUMNA IZQUIERDA: MENSAJE Y DISEÑO DE MARCA -->
                        <div class="col-lg-6 bg-primary d-none d-lg-flex vh-100 flex-column justify-content-between p-5 text-white position-relative pattern-bg" style="min-height: 620px;">
                            <!-- Capa de gradiente oscuro para asegurar contraste -->
                            <div class="position-absolute top-0 start-0 w-100 h-100 bg-gradient opacity-25" style="background: linear-gradient(135deg, #000 0%, #1e40af 100%); pointer-events: none;"></div>

                            <div class="position-relative z-1">
                                <span class="badge bg-white text-primary px-3 py-2 rounded-pill fw-bold small text-uppercase tracking-wider shadow-sm mb-4">
                                    <i class="bi bi-mortarboard-fill me-1.5"></i> Portal Institucional
                                </span>
                                <h1 class="display-5 fw-black mt-3 lh-sm">Tu futuro educativo comienza aquí</h1>
                                <p class="lead text-white-50 mt-3">Gestiona tus sedes, consulta información académica y conecta con nuestra comunidad en un solo lugar.</p>
                            </div>

                            <!-- Lista de beneficios/características -->
                            <div class="position-relative z-1 my-4">
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    <div class="bg-white bg-opacity-10 p-2.5 rounded-3 border border-white border-opacity-10">
                                        <i class="bi bi-lightning-charge-fill text-white fs-5"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-bold text-white">Búsqueda y Comparativa Veloz</h6>
                                        <small class="text-white-50">Explora sedes y toma decisiones informadas al instante.</small>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-white bg-opacity-10 p-2.5 rounded-3 border border-white border-opacity-10">
                                        <i class="bi bi-shield-lock-fill text-white fs-5"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-bold text-white">Privacidad Garantizada</h6>
                                        <small class="text-white-50">Protección estricta para alumnos, tutores y docentes.</small>
                                    </div>
                                </div>
                            </div>

                            <div class="position-relative z-1 mt-auto pt-3 border-top border-white border-opacity-10">
                                <small class="text-white-50">© 2026 EduDirectory. Todos los derechos reservados.</small>
                            </div>

                        </div>

                        <!-- COLUMNA DERECHA: FORMULARIOS INTERACTIVOS -->
                        <div class="col-lg-6 bg-white p-4 p-sm-5 d-flex align-items-center vh-100">
                            <div class="w-100">
                                @{
                                    var mensajeLogin = TempData["MensajeLogin"]?.ToString()
                                                    ?? HttpContext.Request.Query["mensaje"].ToString();
                                }

                                @if (!string.IsNullOrEmpty(mensajeLogin))
                                {
                                    <div class="alert alert-warning d-flex align-items-center gap-2 mb-4" role="alert">
                                        <i class="bi bi-exclamation-triangle-fill"></i>
                                        <span>@mensajeLogin</span>
                                    </div>
                                }
                                <!-- ================= FORMULARIO DE INICIO DE SESIÓN ================= -->
                                <div id="loginContainer" class="fade-in-custom">
                                    <div class="mb-4">
                                        <h3 class="fw-bold text-dark mb-1">¡Hola de nuevo!</h3>
                                        <p class="text-muted small">Ingresa tus credenciales para acceder a tu cuenta.</p>
                                    </div>
                                    <form id="account" class="needs-validation" asp-page="/Account/Login" asp-area="Identity" method="post">
                                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                                        <div class="form-floating mb-3">
                                            <div class="input-group">
                                                <span class="input-group-text bg-light border-end-0 text-muted">
                                                    <i class="bi bi-envelope"></i>
                                                </span>
                                                <input asp-for="Input.Email" class="form-control bg-light border-start-0 py-2.5" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                                            </div>
                                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                                        </div>

                                        <!-- Campo Password -->
                                        <div class="form-floating mb-3">
                                            <div class="input-group">
                                                <span class="input-group-text bg-light border-end-0 text-muted">
                                                    <i class="bi bi-lock"></i>
                                                </span>
                                                <input asp-for="Input.Password" class="form-control bg-light border-start-0 py-2.5" autocomplete="current-password" aria-required="true" placeholder="••••••••" />
                                            </div>
                                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                                        </div>

                                        <div class="checkbox mb-3">
                                            <label asp-for="Input.RememberMe" class="form-label">
                                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                                @Html.DisplayNameFor(m => m.Input.RememberMe)
                                            </label>
                                        </div>
                                        <div>
                                            <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Iniciar sesion</button>
                                        </div>
                                        <div>
                                            <p>
                                                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Regístrate como nuevo usuario</a>
                                            </p>
                                            <p>
                                                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Regresar </a>
                                            </p>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>


