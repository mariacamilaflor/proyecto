@model EduDirectory3.ViewModels.ColegioResultadoViewModel
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EduDirectory - Detalle Institución</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
            :root {
                --edu-blue: #1D4ED8;
                --edu-bg-light: #F8FAFC;
            }

            body {
                background-color: #f1f5f9;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            }

            /* Estilos de la Modal */
            .modal-content {
                border-radius: 1rem;
                border: none;
                overflow: hidden;
                box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);
            }

            .nav-tabs {
                border-bottom: 1px solid #f1f5f9;
                background-color: var(--edu-bg-light);
            }

            .nav-link {
                color: #64748b;
                font-weight: 600;
                border: none !important;
                padding: 1rem 1.5rem;
                font-size: 0.9rem;
            }

                .nav-link.active {
                    color: var(--edu-blue) !important;
                    background: white !important;
                    border-bottom: 3px solid var(--edu-blue) !important;
                }

            /* Tarjetas de Información */
            .info-card {
                border: 1px solid #f1f5f9;
                border-radius: 0.75rem;
                padding: 1.25rem;
                height: 100%;
                transition: all 0.2s;
            }

            .icon-box {
                width: 48px;
                height: 48px;
                background-color: #eff6ff;
                color: var(--edu-blue);
                border-radius: 0.5rem;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.25rem;
            }

            /* Calificaciones por Áreas */
            .rating-detail-box {
                background-color: #f8fafc;
                border-top: 1px solid #f1f5f9;
                padding: 1rem;
            }

            .rating-item p {
                font-size: 0.65rem;
                font-weight: 700;
                text-transform: uppercase;
                color: #94a3b8;
                margin-bottom: 2px;
            }

            .star-active {
                color: #facc15;
            }

            .star-inactive {
                color: #cbd5e1;
            }

            .btn-edu-primary {
                background-color: var(--edu-blue);
                color: white;
                font-weight: 700;
                border-radius: 0.5rem;
                padding: 0.6rem 1.5rem;
                border: none;
            }

                .btn-edu-primary:hover {
                    background-color: #1e40af;
                    color: white;
                }
    </style>
</head>
<body>
    <div class="container">
        <button type="button" class="btn btn-edu-primary d-inline-flex w-100 justify-content-center align-items-center me-2" data-bs-toggle="modal" data-bs-target="#modalInstitucion">
            Ver Detalle Colegio
        </button>
    </div>

    <div class="modal fade" id="modalInstitucion" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header border-0 p-4 p-sm-5 pb-3">
                    <div class="d-flex align-items-center gap-4">
                        <div class="border rounded-3 p-2 bg-white shadow-sm" style="width: 100px; height: 100px;">
                            <img src="@Model.Imagen" class="img-fluid rounded" alt="Logo">
                        </div>
                        <div>
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="badge rounded-pill bg-primary-subtle text-primary text-uppercase px-3 py-2" style="font-size: 0.65rem;">@Model.Tipo</span>
                                <span class="text-warning fw-bold small">
                                    <i class="bi bi-star-fill me-1"></i>
                                    @Model.Opinion.PromedioRating.ToString("0.0")
                                </span>
                            </div>
                            <h2 class="fw-bold mb-1 text-dark">@Model.Nombre</h2>
                            <p class="text-muted small mb-0"><i class="bi bi-geo-alt-fill text-primary me-1"></i>@Model.Sedes.Comuna, @Model.Sedes.Comuna</p>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <ul class="nav nav-tabs px-4" id="instTab" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#general" type="button">Información General</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#academico" type="button">Académico</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#sedes" type="button">Sedes</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#contacto" type="button">Contacto</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#opiniones" type="button">Opiniones</button>
                    </li>
                </ul>
                <div class="modal-body p-2 p-md-4">
                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="general">
                            <div class="row g-4 p-4">
                                <div class="col-md-8">
                                    <h5 class="fw-bold mb-3">Sobre la Institución</h5>
                                    <p class="text-muted">@Model.Descripcion</p>
                                    <div class="row g-3 mt-2">
                                        <div class="col-6">
                                            <div class="info-card d-flex align-items-center gap-3">
                                                <div class="icon-box"><i class="bi bi-calendar-event"></i></div>
                                                <div>
                                                    <small class="text-uppercase fw-bold text-muted d-block" style="font-size: 0.6rem;">Calendario</small>
                                                    <span class="fw-bold">@Model.Calendario</span>
                                                </div>
                                            </div>
                                        </div>
                                        @if (Model.Costo > 0)
                                        {
                                            <div class="col-6">
                                                <div class="info-card d-flex align-items-center gap-3">
                                                    <div class="icon-box text-success bg-success-subtle"><i class="bi bi-currency-dollar"></i></div>
                                                    <div>
                                                        <small class="text-uppercase fw-bold text-muted d-block" style="font-size: 0.6rem;">Matrícula</small>
                                                        <span class="fw-bold">@Model.Costo</span>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                        <div class="col-6">
                                            <div class="info-card d-flex align-items-center gap-3">
                                                <div class="icon-box"><i class="bi bi-calendar-event"></i></div>
                                                <div>
                                                    <small class="text-uppercase fw-bold text-muted d-block" style="font-size: 0.6rem;">Metodologia</small>
                                                    <span class="fw-bold">@Model.Metodologia</span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="info-card d-flex align-items-center gap-3">
                                                <div class="icon-box"><i class="bi bi-globe"></i></div>
                                                <div>
                                                    <small class="text-uppercase fw-bold text-muted d-block" style="font-size: 0.6rem;">Sitio Web Oficial</small>
                                                    <a href="@Model.PaginaWeb" class="text-primary font-bold small text-decoration-none">@Model.PaginaWeb <i class="bi bi-box-arrow-up-right ms-1"></i></a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="mt-4 p-3 border border-primary-subtle bg-primary-subtle bg-opacity-10 rounded-4">
                                        <p class="small fw-bold text-primary mb-1"><i class="bi bi-clock me-1"></i> Horario de Atención</p>
                                        <p class="text-muted mb-0" style="font-size: 0.75rem;">@Model.HorarioAtencion</p>
                                    </div>
                                    <div class="bg-light p-4 rounded-4 border mt-2">
                                        <h6 class="fw-bold text-uppercase mb-3" style="font-size: 0.75rem;">Sedes</h6>
                                        <ul class="list-unstyled mb-0">
                                            @foreach (var sede in Model.Sedes.NombreSede)
                                            {
                                                <li class="mb-2 small fw-semibold text-secondary"><i class="bi bi-check-circle-fill text-primary me-2"></i> @sede</li>
                                            }
                                        </ul>
                                    </div>

                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="academico">
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <div class="info-card">
                                        <h5 class="fw-bold mb-4"><i class="bi bi-award text-primary me-2"></i> Resultados ICFES</h5>
                                        @foreach (var resultados in Model.Academico.Anios.Zip(Model.Academico.Puntajes, (anio, puntaje) => new { Anio = anio, Puntaje = puntaje }))
                                        {
                                            <div class="bg-light p-3 rounded-3 d-flex justify-content-between align-items-center mb-2">

                                                <span class="fw-bold text-secondary">Año @resultados.Anio</span>
                                                <div class="text-end">
                                                    <div class="h4 fw-black text-primary mb-0">@resultados.Puntaje</div>
                                                    @if (resultados.Puntaje >= 0 && resultados.Puntaje <= 199)
                                                    {
                                                        <small class="text-uppercase fw-bold text-muted" style="font-size: 0.6rem;">Inferior</small>
                                                    }
                                                    else if (resultados.Puntaje >= 200 && resultados.Puntaje <= 349)
                                                    {
                                                        <small class="text-uppercase fw-bold text-muted" style="font-size: 0.6rem;">Promedio</small>
                                                    }
                                                    else
                                                    {
                                                        <small class="text-uppercase fw-bold text-muted" style="font-size: 0.6rem;">Superior</small>
                                                    }
                                                </div>

                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="opiniones">

                            @if (Model.Opinion.Comentarios.Count > 0)
                            {
                                @foreach (var comentario in Model.Opinion.Comentarios.Select((texto, index) => new
                                {
                                    Texto = texto,
                                    Index = index
                                }))
                                {
                                    var ambiente = Model.Opinion.Ambiente.ElementAtOrDefault(comentario.Index);
                                    var seguridad = Model.Opinion.Seguridad.ElementAtOrDefault(comentario.Index);
                                    var metodologia = Model.Opinion.Metodologia.ElementAtOrDefault(comentario.Index);
                                    var profesores = Model.Opinion.Profesores.ElementAtOrDefault(comentario.Index);
                                    var actividades = Model.Opinion.ActividadesEx.ElementAtOrDefault(comentario.Index);
                                    var infraestructura = Model.Opinion.Infraestructura.ElementAtOrDefault(comentario.Index);

                                    var nombre = Model.Opinion.Nombres.ElementAtOrDefault(comentario.Index);
                                    var apellido = Model.Opinion.Apellidos.ElementAtOrDefault(comentario.Index);

                                    var promedio =
                                        (ambiente +
                                        seguridad +
                                        metodologia +
                                        profesores +
                                        actividades +
                                        infraestructura) / 6;

                                    <div class="card border rounded-4 overflow-hidden mb-4 shadow-sm">

                                        <div class="card-body p-4">

                                            <div class="d-flex justify-content-between align-items-center mb-3">

                                                <div class="d-flex align-items-center gap-3">
                                                    <div>
                                                        <p class="mb-0 fw-bold small">
                                                            @nombre @apellido
                                                        </p>
                                                    </div>
                                                </div>

                                                <span class="badge bg-warning-subtle text-warning px-3 py-2">
                                                    <i class="bi bi-star-fill me-2"></i>
                                                    @promedio.ToString("0.0")
                                                </span>

                                            </div>

                                            <p class="text-muted small fst-italic">
                                                "@comentario.Texto"
                                            </p>

                                        </div>

                                        <div class="rating-detail-box">

                                            <div class="row text-center g-2">

                                                <div class="col-6 col-md-3 rating-item">
                                                    <p>Infraestructura</p>

                                                    <div class="small">
                                                        @for (int i = 1; i <= 5; i++)
                                                        {
                                                            <i class="@ObtenerClaseEstrella(infraestructura, i)"></i>
                                                        }
                                                    </div>
                                                </div>

                                                <div class="col-6 col-md-3 rating-item">
                                                    <p>Profesores</p>

                                                    <div class="small">
                                                        @for (int i = 1; i <= 5; i++)
                                                        {
                                                            <i class="@ObtenerClaseEstrella(profesores, i)"></i>
                                                        }
                                                    </div>
                                                </div>

                                                <div class="col-6 col-md-3 rating-item">
                                                    <p>Metodología</p>

                                                    <div class="small">
                                                        @for (int i = 1; i <= 5; i++)
                                                        {
                                                            <i class="@ObtenerClaseEstrella(metodologia, i)"></i>
                                                        }
                                                    </div>
                                                </div>

                                                <div class="col-6 col-md-3 rating-item">
                                                    <p>Ambiente</p>

                                                    <div class="small">
                                                        @for (int i = 1; i <= 5; i++)
                                                        {
                                                            <i class="@ObtenerClaseEstrella(ambiente, i)"></i>
                                                        }
                                                    </div>
                                                </div>

                                                <div class="col-6 col-md-3 rating-item">
                                                    <p>Seguridad</p>

                                                    <div class="small">
                                                        @for (int i = 1; i <= 5; i++)
                                                        {
                                                            <i class="@ObtenerClaseEstrella(seguridad, i)"></i>
                                                        }
                                                    </div>
                                                </div>

                                                <div class="col-6 col-md-3 rating-item">
                                                    <p>Actividades</p>

                                                    <div class="small">
                                                        @for (int i = 1; i <= 5; i++)
                                                        {
                                                            <i class="@ObtenerClaseEstrella(actividades, i)"></i>
                                                        }
                                                    </div>
                                                </div>

                                            </div>

                                        </div>

                                    </div>
                                }
                            }
                            else
                            {
                                <div class="alert alert-light border rounded-4">
                                    Aún no hay opiniones registradas.
                                </div>
                            }

                        </div>

                        <div class="tab-pane fade" id="contacto">
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <div class="info-card">
                                        <div class="d-flex align-items-center gap-3 mb-3">
                                            <div class="icon-box bg-dark text-white"><i class="bi bi-person-badge"></i></div>
                                            <div>
                                                <h5 class="fw-bold mb-0">Rectoría</h5>
                                            </div>
                                        </div>

                                        <div class="contact-item mb-1">
                                            <span class="text-muted small fw-bold text-uppercase me-2">Rector</span>
                                            <span class="fw-bold text-dark">@Model.Contacto.RectorNombre @Model.Contacto.RectorApellido</span>
                                        </div>

                                        <div class="contact-item cursor-pointer mb-1">
                                            <div class="d-flex align-items-center gap-2">
                                                <i class="bi bi-envelope text-primary"></i>
                                                <span class="text-dark small fw-semibold">@Model.Contacto.RectorEmail</span>
                                            </div>
                                        </div>

                                        <div class="contact-item mb-1">
                                            <div class="d-flex align-items-center gap-2">
                                                <i class="bi bi-telephone text-primary"></i>
                                                <span class="text-dark small fw-semibold">@Model.Contacto.RectorTelefono</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6 d-flex flex-column gap-4">
                                    <div class="info-card h-100">
                                        <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-telephone-outbound me-2 text-primary"></i>Directorio de Contacto</h5>
                                        <!-- Sección de Correos -->
                                        <label class="contact-label">Correos Electrónicos</label>
                                        <div class="row">
                                            @foreach (var item in Model.Sedes.Email.Select((email, index) => new
                                            {
                                                Email = email,
                                                Index = index
                                            }))
                                            {
                                                var perteneceA = Model.Sedes.PerteneceA.ElementAtOrDefault(item.Index);
                                                <div class="col-md-6 mb-2">
                                                    <div class="contact-item">
                                                        <div class="d-flex align-items-center gap-2">
                                                            <i class="bi bi-envelope-fill text-primary"></i>

                                                            <div class="ms-1">
                                                                <p class="mb-0 text-dark small fw-bold">
                                                                    @perteneceA
                                                                </p>

                                                                <p class="mb-0 text-muted" style="font-size: 0.75rem;">
                                                                    @item.Email
                                                                </p>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="sedes">
                            @{
                                var sedes = Model.Sedes.NombreSede.ToList();
                            }
                            <div class="container">
                                @if (sedes.Any())
                                {
                                    <!-- Navegación de las pestañas (Diseño premium tipo Pill/Botón interactivo) -->
                                    <ul class="nav nav-underline gap-4 p-0 mb-3" id="sedesTab" role="tablist" style="--bs-nav-link-color: var(--bs-gray-600); --bs-nav-underline-border-width: 3px;">
                                        @for (int i = 0; i < sedes.Count; i++)
                                        { 

                                           

                                            var sede = sedes[i];
                                            var isActive = i == 0 ? "active" : "";
                                            <li class="nav-item" role="presentation">
                                                <button class="nav-link rounded-4 px-3 py-1.5 fw-semibold @isActive"
                                                        id="tab-@i"
                                                        data-bs-toggle="tab"
                                                        data-bs-target="#panel-@i"
                                                        type="button"
                                                        role="tab"
                                                        aria-controls="panel-@i"
                                                        aria-selected="@(i == 0 ? "true" : "false")"
                                                        style="font-size: 0.825rem;">
                                                    <i class="bi bi-building me-1.5 small"></i>@sede
                                                </button>
                                            </li>
                                        }
                                    </ul>
                                    <!-- Contenedor de las pestañas -->
                                    <div class="tab-content" id="sedesTabContent">
                                        @for (int i = 0; i < sedes.Count; i++)
                                        {
                                            var item = sedes[i];
                                            var servicios = Model.Academico.Servicios.ElementAtOrDefault(i)
                                                ?? new List<string>();
                                                
                                            var niveles = Model.Academico.Niveles.ElementAtOrDefault(i)
                                                ?? new List<string>();

                                            var jornadas = Model.Academico.Jornadas.ElementAtOrDefault(i)
                                                ?? new List<string>();

                                            var actividades = Model.Academico.ActividadesExtracurriculares.ElementAtOrDefault(i)
                                                ?? new List<string>();

                                            var telefono = Model.Sedes.Telefono.ElementAtOrDefault(i)
                                                ?? new List<string>();
                                            var isActive = i == 0 ? "show active" : "";

                                            <div class="tab-pane fade @isActive" id="panel-@i" role="tabpanel" aria-labelledby="tab-@i">
                                                <!-- Tarjeta Principal de la Sede Activa -->
                                                <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                                                    <div class="card-body p-3">
                                                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-4 border-bottom pb-3">
                                                            <div>
                                                                <h3 class="card-title mb-1 text-dark fw-bold">
                                                                    @item
                                                                </h3>
                                                                <div class="text-secondary d-flex align-items-center gap-2">
                                                                    <i class="bi bi-geo-alt-fill text-primary fs-5"></i>
                                                                    <span>@item</span>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="row g-4 mb-4">
                                                            <!-- Servicios -->
                                                            <div class="col-md-6 col-lg-3">
                                                                <div class="p-3 bg-light rounded-4 border border-light-subtle h-100 d-flex flex-column justify-content-between">
                                                                    <div>
                                                                        <p class="text-primary text-uppercase font-black small tracking-widest mb-3 d-flex align-items-center gap-2 fw-bold" style="font-size: 11px;">
                                                                            <span class="p-1 bg-primary rounded-circle d-inline-block" style="width: 6px; height: 6px;"></span> Servicios
                                                                        </p>
                                                                        <div class="d-flex flex-wrap gap-2">
                                                                            @foreach (var servicio in servicios)
                                                                            {
                                                                                <span class="badge bg-white text-dark border border-gray px-3 py-2 rounded-2 text-wrap text-start">
                                                                                    <small class="text-uppercase fw-semibold d-block" style="font-size: 0.65rem;">@servicio</small>
                                                                                </span>
                                                                            }
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <!-- Niveles -->
                                                            <div class="col-md-6 col-lg-3">
                                                                <div class="p-3 bg-light rounded-4 border border-light-subtle h-100 d-flex flex-column justify-content-between">
                                                                    <div>
                                                                        <p class="text-primary text-uppercase font-black small tracking-widest mb-3 d-flex align-items-center gap-2 fw-bold" style="font-size: 11px;">
                                                                            <span class="p-1 bg-success rounded-circle d-inline-block" style="width: 6px; height: 6px;"></span> Niveles
                                                                        </p>
                                                                        <div class="d-flex flex-wrap gap-2">
                                                                            @foreach (var nivel in niveles)
                                                                            {
                                                                                <span class="badge bg-white text-dark border border-gray px-3 py-2 rounded-2 text-wrap text-start">
                                                                                    <small class="text-uppercase fw-semibold d-block" style="font-size: 0.65rem;">@nivel</small>
                                                                                </span>
                                                                            }
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <!-- Jornadas -->
                                                            <div class="col-md-6 col-lg-3">
                                                                <div class="p-3 bg-light rounded-4 border border-light-subtle h-100 d-flex flex-column justify-content-between">
                                                                    <div>
                                                                        <p class="text-primary text-uppercase font-black small tracking-widest mb-3 d-flex align-items-center gap-2 fw-bold" style="font-size: 11px;">
                                                                            <span class="p-1 bg-warning rounded-circle d-inline-block" style="width: 6px; height: 6px;"></span> Jornadas
                                                                        </p>
                                                                        <div class="d-flex flex-wrap gap-2">
                                                                            @foreach (var jornada in jornadas)
                                                                            {
                                                                                <span class="badge bg-white text-dark border border-gray px-3 py-2 rounded-2 text-wrap text-start">
                                                                                    <small class="text-uppercase fw-semibold d-block" style="font-size: 0.65rem;">@jornada</small>
                                                                                </span>
                                                                            }
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <!-- Actividades Extracurriculares -->
                                                            <div class="col-md-6 col-lg-3">
                                                                <div class="p-3 bg-light rounded-4 border border-light-subtle h-100 d-flex flex-column justify-content-between">
                                                                    <div>
                                                                        <p class="text-primary text-uppercase font-black small tracking-widest mb-3 d-flex align-items-center gap-2 fw-bold" style="font-size: 11px;">
                                                                            <span class="p-1 bg-info rounded-circle d-inline-block" style="width: 6px; height: 6px;"></span> Extraescolares
                                                                        </p>
                                                                        <div class="d-flex flex-wrap gap-2">
                                                                            @foreach (var actividad in actividades)
                                                                            {
                                                                                <span class="badge bg-white text-dark border border-gray px-3 py-2 rounded-2 text-wrap text-start">
                                                                                    <small class="text-uppercase fw-semibold d-block" style="font-size: 0.65rem;">@actividad</small>
                                                                                </span>
                                                                            }
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <!-- Sección de Teléfonos (Corregida para pertenecer únicamente a la Sede actual) -->
                                                        <div class="border-top pt-4">
                                                            <h6 class="text-dark fw-bold mb-3 d-flex align-items-center gap-2">
                                                                <i class="bi bi-telephone text-primary"></i> Líneas Telefónicas de Atención
                                                            </h6>
                                                            <div class="row g-3">
                                                                @if (telefono.Count()>0)
                                                                {
                                                                    @foreach (var tel in telefono)
                                                                    {
                                                                        <div class="col-sm-6 col-md-4">
                                                                            <div class="p-3 rounded-3 border bg-white d-flex align-items-center gap-3 shadow-xs h-100">
                                                                                <div class="icon-box bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; flex-shrink: 0;">
                                                                                    <i class="bi bi-phone"></i>
                                                                                </div>
                                                                                <div>
                                                                                    <p class="mb-0 text-muted fw-semibold" style="font-size: 0.7rem; text-transform: uppercase;">Central Telefónica</p>
                                                                                    <a href="tel:#" class="mb-0 text-dark fw-bold text-decoration-none hover-primary">
                                                                                        @tel
                                                                                    </a>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    }
                                                                }
                                                                else
                                                                {
                                                                    <div class="col-12">
                                                                        <p class="text-muted small italic">No hay teléfonos registrados para esta sede.</p>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>

                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="text-center py-5">
                                        <i class="bi bi-building-exclamation text-muted fs-1 mb-3"></i>
                                        <p class="text-muted">No se encontraron sedes disponibles en este momento.</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
@functions {

    public string ObtenerClaseEstrella(decimal nota, int posicion)
    {
        if (nota >= posicion)
        {
            return "bi bi-star-fill star-active";
        }
        else if (nota >= posicion - 0.5m)
        {
            return "bi bi-star-half star-active";
        }

        return "bi bi-star star-inactive";
    }

}