    </div>
    <div id="resenaContainer"></div>
    <div class="modal fade" id="motivoModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Motivo del reporte</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <textarea id="motivoInput" class="form-control" placeholder="Escriba el motivo"></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" onclick="enviarReporte()">Reportar</button>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
@functions {
    public string ObtenerClaseEstrella(decimal nota, int posicion)
    {
        if (nota >= posicion)
        {
            return "bi bi-star-fill star-active";
        }
        else if (nota >= posicion - 0.5m)
        {
            return "bi bi-star-half star-active";
        }

        return "bi bi-star star-inactive";
    }
}

<script>
    async function abrirModalResena(idInstitucion) {
        // 1. Pide el modal al servidor
        const res = await fetch(`/Evaluacion/ModalResena?idInstitucion=${idInstitucion}`);
        if (!res.ok) { alert('No se pudo cargar el formulario.'); return; }

        // 2. Inyecta el HTML en el DOM
        const html = await res.text();
        document.getElementById('resenaContainer').innerHTML = html;

        // 3. Re-ejecuta los scripts del partial (necesario para el fetch dinámico)
        document.getElementById('resenaContainer').querySelectorAll('script').forEach(old => {
            const s = document.createElement('script');
            s.textContent = old.textContent;
            document.body.appendChild(s);
        });
        $(`#modalInstitucion-${idInstitucion}`).modal('hide');
    }



    function reportarResena(idEvaluacion) {
        evaluacionIdSeleccionada = idEvaluacion;
        $('#motivoModal').modal('show'); // abre el modal para escribir motivo
    }

    async function enviarReporte() {
        const motivo = document.getElementById("motivoInput").value;
        if (!motivo) return;

        const res = await fetch(`/Evaluacion/Reportar`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ idEvaluacion: evaluacionIdSeleccionada, motivoReporte: motivo })
        });

        $('#motivoModal').modal('hide'); // cierra el modal de motivo

        if (res.ok) {
            mostrarMensaje("La reseña fue reportada correctamente.");
        } else {
            mostrarMensaje("Error al reportar la reseña.");
        }
    }

    function mostrarMensaje(mensaje) {
        document.getElementById("mensajeModalBody").innerText = mensaje;
        body.innerText = "";
        $('#mensajeModal').modal('show'); // abre el modal de aviso
    }


    document.addEventListener('DOMContentLoaded', function () {

        const descripcionesMetodologia = {
            "Gamificación": "Usa elementos de juegos como puntos, retos y recompensas para motivar el aprendizaje.",
            "Educación Tradicional": "Modelo clásico centrado en el docente, con clases magistrales y evaluaciones escritas.",
            "Aprendizaje Basado en Proyectos (ABP)": "Los estudiantes aprenden resolviendo proyectos reales o simulados.",
            "Aprendizaje Cooperativo": "Fomenta el trabajo en equipo para alcanzar objetivos comunes.",
            "Aprendizaje Basado en Competencias": "Se enfoca en desarrollar habilidades prácticas aplicables al mundo real.",
            "Flipped Classroom (Aula Invertida)": "El estudiante estudia el contenido en casa y practica en clase con el docente.",
            "Pedagogías alternativas": "Enfoques no convencionales como Montessori, Waldorf o Reggio Emilia."
        };

        // Asignar descripción según metodología y activar tooltip
        document.querySelectorAll('[data-metodologia]').forEach(el => {
            const metodologia = el.dataset.metodologia;
            el.setAttribute('title', descripcionesMetodologia[metodologia] || metodologia);
            new bootstrap.Tooltip(el);
        });

        document.querySelectorAll('[data-tooltip]').forEach(el => {
            new bootstrap.Tooltip(el, {
                title: el.dataset.tooltip,
                placement: 'top',
                trigger: 'hover'  // solo al pasar el mouse, no interfiere con el click del tab
            });
        });

        // Activar el resto de tooltips normales
        document.querySelectorAll('[data-bs-toggle="tooltip"]:not([data-metodologia])').forEach(el => {
            new bootstrap.Tooltip(el);
        });
    });
       document.getElementById('modalInstitucion-@Model.IdInstitucion')
        .addEventListener('show.bs.modal', async function () {
            const res = await fetch('/Favorito/EsFavorito?idInstitucion=@Model.IdInstitucion');
            const data = await res.json();
            const btn = document.getElementById('btn-fav-@Model.IdInstitucion');
            const icono = btn.querySelector('i');

            if (data.esFavorito) {
                icono.classList.remove('bi-heart');
                icono.classList.add('bi-heart-fill');
                btn.classList.remove('btn-outline-warning');
                btn.classList.add('btn-warning');
            } else {
                icono.classList.remove('bi-heart-fill');
                icono.classList.add('bi-heart');
                btn.classList.remove('btn-warning');
                btn.classList.add('btn-outline-warning');
            }
        });


</script>

