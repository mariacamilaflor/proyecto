@{
}
const mapa = L.map('mapa').setView([6.3294, -75.5592], 13);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(mapa);

const sedes = @Html.Raw(ViewBag.SedesJson);
sedes.forEach(s => {
L.marker([s.lat, s.lng]).addTo(mapa)
.bindPopup(`<strong>${s.institucion}</strong>
<br />
${s.direccion}
<br />
<a href="/Colegios/Detalle/${s.idInstitucion}">Ver detalle</a>`);
});