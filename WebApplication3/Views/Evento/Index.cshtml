@model List<EduDirectory3.Models.Evento>
@{
    ViewData["Title"] = "Eventos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <div style="width:44px;height:44px;background:#e0f2fe;border-radius:10px;display:flex;align-items:center;justify-content:center;">
            <i class="bi bi-calendar-event-fill" style="color:#0369a1;font-size:20px;"></i>
        </div>
        <div>
            <h4 class="fw-bold mb-0">Eventos próximos</h4>
            <small class="text-muted">Descubre lo que está pasando en las instituciones</small>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-calendar-x" style="font-size:48px;display:block;margin-bottom:12px;"></i>
            <p>No hay eventos próximos por el momento.</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var evento in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border rounded-3 p-3">
                        <div style="background:#e0f2fe;border-radius:8px;padding:10px 14px;margin-bottom:12px;">
                            <div style="font-size:22px;font-weight:700;color:#0369a1;">
                                @evento.Fecha.ToString("dd")
                            </div>
                            <div style="font-size:12px;color:#0369a1;text-transform:uppercase;">
                                @evento.Fecha.ToString("MMM yyyy")
                            </div>
                        </div>
                        <h6 class="fw-bold mb-1">@evento.Titulo</h6>
                        <p class="text-muted small mb-2">@evento.Descripcion</p>
                        <div class="mt-auto">
                            <small class="text-secondary d-block">
                                <i class="bi bi-geo-alt me-1"></i>@evento.Lugar
                            </small>
                            <small class="text-primary d-block mt-1">
                                <i class="bi bi-building me-1"></i>@evento.Institucion.Nombre
                            </small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>