@model EduDirectory3.ViewModels.FormularioPreferenciaViewModel
@{
    ViewData["Title"] = "Encuentra tu colegio ideal";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4" style="max-width:680px;">
    <div class="d-flex align-items-center gap-3 mb-4">
        <div style="width:44px;height:44px;background:#ede9fe;border-radius:10px;display:flex;align-items:center;justify-content:center;">
            <i class="bi bi-stars" style="color:#7c3aed;font-size:20px;"></i>
        </div>
        <div>
            <h4 class="fw-bold mb-0">Encuentra tu colegio ideal</h4>
            <small class="text-muted">Cuéntanos tus preferencias y te recomendamos los mejores</small>
        </div>
    </div>

    <form asp-action="Index" method="post">
        @Html.AntiForgeryToken()

        @* Básico *@
        <div class="card border rounded-3 p-4 mb-3">
            <h6 class="fw-bold mb-3"><i class="bi bi-person me-2 text-primary"></i>Información básica</h6>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Edad del estudiante</label>
                    <input asp-for="EdadEstudiante" type="number" class="form-control" min="3" max="18" placeholder="Ej: 10" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Presupuesto mensual</label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="Presupuesto" type="number" class="form-control" placeholder="Ej: 500000" />
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Tipo de institución</label>
                    <select asp-for="TipoPreferencia" class="form-control">
                        <option value="">-- Selecciona --</option>
                        <option value="Pública">Pública</option>
                        <option value="Privada">Privada</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Metodología preferida</label>
                    <select asp-for="MetodologiaPreferencia" class="form-control">
                        <option value="">-- Selecciona --</option>
                        <option value="Educación Tradicional">Educación Tradicional</option>
                        <option value="Aprendizaje Basado en Proyectos (ABP)">ABP</option>
                        <option value="Gamificación">Gamificación</option>
                        <option value="Flipped Classroom (Aula Invertida)">Aula Invertida</option>
                        <option value="Aprendizaje Cooperativo">Aprendizaje Cooperativo</option>
                        <option value="Aprendizaje Basado en Competencias">Basado en Competencias</option>
                        <option value="Pedagogías alternativas">Pedagogías alternativas</option>
                    </select>
                </div>
            </div>
        </div>

        @* Jornadas *@
        <div class="card border rounded-3 p-4 mb-3">
            <h6 class="fw-bold mb-3"><i class="bi bi-clock me-2 text-primary"></i>Jornada preferida</h6>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var j in new[] { "Mañana", "Tarde", "Noche", "Completa", "Sabatina" })
                {
                    <label class="badge-check">
                        <input type="checkbox" name="JornadasSeleccionadas" value="@j" />
                        <span>@j</span>
                    </label>
                }
            </div>
        </div>

        @* Niveles *@
        <div class="card border rounded-3 p-4 mb-3">
            <h6 class="fw-bold mb-3"><i class="bi bi-mortarboard me-2 text-primary"></i>Nivel educativo</h6>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var n in new[] { "Preescolar", "Primaria", "Secundaria", "Media", "Técnico", "Tecnológico" })
                {
                    <label class="badge-check">
                        <input type="checkbox" name="NivelesSeleccionados" value="@n" />
                        <span>@n</span>
                    </label>
                }
            </div>
        </div>

        @* Servicios *@
        <div class="card border rounded-3 p-4 mb-3">
            <h6 class="fw-bold mb-3"><i class="bi bi-grid me-2 text-primary"></i>Servicios importantes para ti</h6>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var s in new[] { "Transporte", "Cafetería", "Biblioteca", "Enfermería", "Psicología", "Laboratorio", "Internet", "Aulas virtuales", "Cancha deportiva", "Piscina" })
                {
                    <label class="badge-check">
                        <input type="checkbox" name="ServiciosSeleccionados" value="@s" />
                        <span>@s</span>
                    </label>
                }
            </div>
        </div>

        @* Actividades *@
        <div class="card border rounded-3 p-4 mb-3">
            <h6 class="fw-bold mb-3"><i class="bi bi-trophy me-2 text-primary"></i>Actividades extracurriculares</h6>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var a in new[] { "Fútbol", "Baloncesto", "Natación", "Teatro", "Música", "Danza", "Robótica", "Inglés avanzado", "Artes plásticas", "Ajedrez", "Atletismo", "Voleibol" })
                {
                    <label class="badge-check">
                        <input type="checkbox" name="ActividadesSeleccionadas" value="@a" />
                        <span>@a</span>
                    </label>
                }
            </div>
        </div>

        <button type="submit" class="btn btn-primary w-100 py-3 fw-bold">
            <i class="bi bi-stars me-2"></i> Ver mis colegios recomendados
        </button>
    </form>
</div>

<style>
    .badge-check input {
        display: none;
    }

    .badge-check span {
        display: inline-block;
        padding: 6px 14px;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        font-size: 13px;
        cursor: pointer;
        transition: all 0.15s;
        background: #f8fafc;
    }

    .badge-check input:checked + span {
        background: #ede9fe;
        border-color: #7c3aed;
        color: #7c3aed;
        font-weight: 600;
    }
</style>