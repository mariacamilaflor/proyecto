<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EduDirectory3.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/rateYo/2.3.2/jquery.rateyo.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mt-2 mx-5">
            <div class="container-fluid">

                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img class="" src="/Imagen/logo.png" width="60" height="60">
                    <b>EduDirectory</b>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation"><span class="navbar-toggler-icon"></span></button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link text-secondary m-2" asp-area="" asp-controller="Colegios" asp-action="Index"><b>Directorio</b></a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-secondary m-2" asp-area="" asp-controller="Colegios" asp-action="Mapa"><b>Mapa</b></a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-secondary m-2" href="#" id="btnIrComparador"> (<span id="contadorComparador">0</span>) <b>Comparacion</b></a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-secondary m-2" asp-area="" asp-controller="Evento" asp-action="Index"><b>Eventos</b></a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div>
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted">
        <div class="container">
            &copy; 2026 - WebApplication3 - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    @* Botón flotante — redirige directo al chatbot *@
    <a href="@Url.Action("Index", "Chatbot")"
       class="btn btn-primary rounded-circle shadow"
       style="position:fixed; bottom:28px; right:28px; width:56px; height:56px; z-index:1050; border:none; display:flex; align-items:center; justify-content:center;"
       data-bs-toggle="tooltip" title="Presiona para conversar con el chatbot"
       aria-label="Abrir asistente">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
             fill="white" viewBox="0 0 24 24">
            <path d="M20 2H4a2 2 0 0 0-2 2v18l4-4h14a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2z" />
        </svg>
    </a>
    <a href="@Url.Action("Index", "PQR")"
       class="btn btn-danger rounded-circle shadow"
       style="position:fixed; bottom:96px; right:28px; width:56px; height:56px; z-index:1050; border:none; display:flex; align-items:center; justify-content:center;"
       aria-label="Abrir PQR"
       title="Peticiones, Quejas y Reclamos">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
             fill="white" viewBox="0 0 24 24">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
            <line x1="9" y1="9" x2="15" y2="9" stroke="white" stroke-width="2" />
            <line x1="9" y1="13" x2="13" y2="13" stroke="white" stroke-width="2" />
        </svg>
    </a>
</body>
</html>